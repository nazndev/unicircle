# Mobile App Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Mobile API Key (get from backend admin)
# ⚠️ SECURITY: This key is exposed in the app bundle. Use request signing for production.
EXPO_PUBLIC_MOBILE_API_KEY=your_mobile_api_key_here

# Mobile API Secret (for request signing - NOT used in app, only for reference)
# This should NEVER be in the mobile app bundle
# MOBILE_API_SECRET=your_secret_here

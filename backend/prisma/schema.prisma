datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model University {
  id        String  @id @default(uuid())
  name      String
  domain    String? @unique
  active    Boolean @default(true)
  allowCrossCampus Boolean @default(false)
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id                String   @id @default(uuid())
  name              String?
  email             String   @unique
  passwordHash      String?
  universityId      String?
  university        University? @relation(fields: [universityId], references: [id])
  department        String?
  programme         String?
  semester          String?
  gender            String?
  avatarUrl         String?
  registrationSource String  @default("student_email") // student_email | alumni_manual
  verificationStatus String  @default("pending")        // pending | approved | rejected
  documents         Json?    // uploaded alumni proofs
  isVerified        Boolean  @default(false)
  isBlocked         Boolean  @default(false)
  allowCrossCampus  Boolean  @default(false)
  profileMode       String   @default("student") // student | alumni | professional
  role              String   @default("user") // user | admin | super_admin
  currentStatus     String?
  headline          String?
  experience        Json?
  skills            Json?
  createdAt         DateTime @default(now())
  crushesSent       Crush[]  @relation("CrushSender")
  crushesRecv       Crush[]  @relation("CrushReceiver")
  matchesA          Match[]  @relation("MatchA")
  matchesB          Match[]  @relation("MatchB")
  reportsFiled      Report[] @relation("ReportBy")
  reportsOn         Report[] @relation("ReportOn")
  groupMembers      GroupMember[]
  groupsCreated     Group[]
  posts             Post[]
  jobsOwned         Job[]
  jobApplications   JobApplication[]
  marketplaceListings MarketplaceListing[]
  transactions      Transaction[]
  chatMessages      ChatMessage[]
  groupMessages     GroupMessage[]
  postComments      PostComment[]
  postLikes         PostLike[]
  alumniApprovals   AlumniApproval[]
  emailVerifications EmailVerification[]
}

model AlumniApproval {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  documents   Json?
  status      String   @default("pending") // pending | approved | rejected
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Crush {
  id          String   @id @default(uuid())
  fromUserId  String
  toUserId    String
  fromUser    User     @relation("CrushSender", fields: [fromUserId], references: [id])
  toUser      User     @relation("CrushReceiver", fields: [toUserId], references: [id])
  status      String   @default("pending") // pending | matched | hidden
  createdAt   DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}

model Match {
  id        String   @id @default(uuid())
  userAId   String
  userBId   String
  userA     User     @relation("MatchA", fields: [userAId], references: [id])
  userB     User     @relation("MatchB", fields: [userBId], references: [id])
  createdAt DateTime @default(now())
  messages  ChatMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([createdAt])
}

model Group {
  id            String   @id @default(uuid())
  title         String
  description   String?
  universityId  String?
  programme     String?
  visibility    String   @default("university") // university | programme | public
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  members       GroupMember[]
  messages      GroupMessage[]
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([createdAt])
}

model Post {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  content     String
  mediaUrl    String?
  visibility  String   @default("university")
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())
  comments    PostComment[]
  likes       PostLike[]

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Job {
  id              String   @id @default(uuid())
  title           String
  description     String
  employmentType  String?
  location        String?
  ownerUserId     String
  ownerUser       User     @relation(fields: [ownerUserId], references: [id])
  targetUniversityId String?
  targetProgramme String?
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  applications    JobApplication[]

  @@index([ownerUserId])
  @@index([isActive])
  @@index([createdAt])
}

model JobApplication {
  id          String   @id @default(uuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User     @relation(fields: [applicantId], references: [id])
  coverLetter String?
  status      String   @default("submitted")
  createdAt   DateTime @default(now())

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
}

model MarketplaceListing {
  id           String   @id @default(uuid())
  type         String   // rent | sale
  category     String   // accommodation | electronics | books | furniture | other
  title        String
  description  String
  price        Float?
  location     String?
  universityId String?
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  images       Json?
  contactInfo  String?
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([ownerId])
  @@index([isActive])
  @@index([category])
  @@index([createdAt])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  context   String   // marketplace | job | premium
  reference String
  amount    Float
  status    String   @default("pending") // pending | paid | failed
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model Report {
  id             String   @id @default(uuid())
  reportedById   String
  reportedBy     User     @relation("ReportBy", fields: [reportedById], references: [id])
  reportedUserId String?
  reportedUser   User?    @relation("ReportOn", fields: [reportedUserId], references: [id])
  reason         String
  contextType    String?
  contextId      String?
  status         String   @default("pending") // pending | resolved | dismissed
  createdAt      DateTime @default(now())

  @@index([reportedById])
  @@index([reportedUserId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

model Settings {
  id                          String   @id @default("platform")
  enableCrossUniversityMatching Boolean @default(false)
  enableMarketplace           Boolean @default(true)
  enableCareerFeatures        Boolean @default(true)
  reportNotificationEmail     String?
  updatedAt                   DateTime @default(now()) @updatedAt
}


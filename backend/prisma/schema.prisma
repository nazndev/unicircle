datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Country {
  id                  String               @id @default(uuid())
  name                String               @unique
  code                String?              @unique // ISO 3166-1 alpha-2 code (e.g., "US", "BD", "GB")
  currency            String               @default("BDT") // ISO 4217 currency code (e.g., "BDT", "USD", "GBP")
  active              Boolean              @default(false) // Countries are inactive by default
  universities        University[]
  organizations       Organization[]
  institutionRequests InstitutionRequest[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt

  @@index([active])
  @@index([name])
  @@index([currency])
}

model University {
  id                    String                @id @default(uuid())
  name                  String
  domain                String?               @unique
  countryId             String
  country               Country               @relation(fields: [countryId], references: [id])
  active                Boolean               @default(true)
  allowCrossCampus      Boolean               @default(false)
  users                 User[]
  researchOpportunities ResearchOpportunity[]
  orders                Order[]
  createdAt             DateTime              @default(now())

  @@index([countryId])
}

model Organization {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "British American Tobacco", "Unilever"
  domain      String?  @unique // e.g., "bat.com", "unilever.com"
  countryId   String?
  country     Country? @relation(fields: [countryId], references: [id])
  active      Boolean  @default(true)
  type        String? // e.g., "corporate", "ngo", "government", "startup"
  website     String?
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([countryId])
  @@index([domain])
}

model InstitutionRequest {
  id              String    @id @default(uuid())
  institutionName String // Generic name (was universityName)
  institutionType String? // "university" | "organization" - set by admin when approving
  countryId       String?
  country         Country?  @relation(fields: [countryId], references: [id])
  studentEmail    String // User's email (can be student or professional)
  domain          String // Extracted from studentEmail
  status          String    @default("pending") // pending | approved | rejected
  requestedBy     String? // User ID if user is logged in
  reviewedBy      String? // Admin ID
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([countryId])
  @@index([institutionType])
}

model User {
  id                        String                @id @default(uuid())
  name                      String?
  nameVerified              Boolean               @default(false) // Name verification badge (requires document verification)
  nameVerificationDocuments Json? // Documents for name verification (office ID, business card, certificate, NID, passport, etc.)
  email                     String                @unique
  personalEmail             String? // Personal email (separate from university/office email)
  secondaryContact          String? // Secondary contact information (phone, email, etc.)
  passwordHash              String?
  universityId              String?
  university                University?           @relation(fields: [universityId], references: [id])
  organizationId            String? // For professionals working at companies
  organization              Organization?         @relation(fields: [organizationId], references: [id])
  department                String? // For students: BBA, CSE, Pharmacy, etc. | For professionals: Department/Division
  programme                 String? // Similar to department, can be used for degree programme
  semester                  String? // For students: current semester/year
  gender                    String?
  dateOfBirth               DateTime? // Date of birth
  phoneNumber               String? // Mobile number for SMS OTP, notifications, etc.
  passingYear               Int? // For students: expected graduation year
  graduationYear            Int? // For alumni: actual graduation year
  bio                       String? // Short bio/about me
  interests                 Json? // Array of interests for matching (crush, research, etc.)
  avatarUrl                 String?
  registrationSource        String                @default("student_email") // student_email | alumni_manual | professional_email
  verificationStatus        String                @default("pending") // pending | approved | rejected
  documents                 Json? // uploaded alumni/professional proofs
  isVerified                Boolean               @default(false)
  isBlocked                 Boolean               @default(false)
  allowCrossCampus          Boolean               @default(false)
  profileMode               String                @default("student") // student | professional (base role)
  isAlumni                  Boolean               @default(false) // Alumni badge (automatically set when transitioning from student to professional, or when directly registering as professional with university info)
  alumniVerified            Boolean               @default(false) // Alumni verification badge (true if student→professional transition, or after admin approval for direct registration)
  isTeacher                 Boolean               @default(false) // Teacher badge (enables research features, can be combined with professional profileMode)
  teacherVerified           Boolean               @default(false) // Teacher verification badge (true if verified with university email, or after admin approval)
  universityEmailVerified   Boolean               @default(false) // Badge: verified with university email
  officeEmailVerified       Boolean               @default(false) // Badge: verified with office email
  role                      String                @default("user") // user | admin | super_admin
  onboardingCompleted       Boolean               @default(false)
  currentStatus             String? // For alumni: current job/position
  headline                  String? // Professional headline
  experience                Json? // For alumni/teachers: work experience
  skills                    Json? // Skills array
  researchInterests         Json? // For teachers: research areas/interests
  createdAt                 DateTime              @default(now())
  crushesSent               Crush[]               @relation("CrushSender")
  crushesRecv               Crush[]               @relation("CrushReceiver")
  matchesA                  Match[]               @relation("MatchA")
  matchesB                  Match[]               @relation("MatchB")
  reportsFiled              Report[]              @relation("ReportBy")
  reportsOn                 Report[]              @relation("ReportOn")
  groupMembers              GroupMember[]
  groupsCreated             Group[]
  posts                     Post[]
  jobsOwned                 Job[]
  jobApplications           JobApplication[]
  marketplaceListings       MarketplaceListing[]
  transactions              Transaction[]
  chatMessages              ChatMessage[]
  groupMessages             GroupMessage[]
  postComments              PostComment[]
  postLikes                 PostLike[]
  alumniApprovals           AlumniApproval[]
  teacherApprovals          TeacherApproval[]
  badges                    UserBadge[]
  emailVerifications        EmailVerification[]
  devices                   Device[]
  researchOpportunities     ResearchOpportunity[] // Teachers publish research
  researchApplications      ResearchApplication[] // Students apply
  // Vendor and commerce relations (added below)
  // Referral system
  referralCode              String                @unique @default(uuid()) // Unique code for referring others
  referredBy                String? // User ID who referred this user
  referredByUser            User?                 @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals                 User[]                @relation("UserReferrals") // Users referred by this user
  referralPoints            Int                   @default(0) // Points earned from referrals
  // Vendor and commerce relations
  vendorOwned                Vendor[]              @relation("VendorOwner")
  orders                     Order[]               @relation("OrderBuyer")
  invoices                   Invoice[]             @relation("InvoiceUser")
}

model AlumniApproval {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  documents  Json?
  status     String    @default("pending") // pending | approved | rejected
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
}

model TeacherApproval {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  documents  Json? // Faculty ID, appointment letter, university verification
  status     String    @default("pending") // pending | approved | rejected
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Crush {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  fromUser   User     @relation("CrushSender", fields: [fromUserId], references: [id])
  toUser     User     @relation("CrushReceiver", fields: [toUserId], references: [id])
  status     String   @default("pending") // pending | matched | hidden
  createdAt  DateTime @default(now())

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
}

model Match {
  id        String        @id @default(uuid())
  userAId   String
  userBId   String
  userA     User          @relation("MatchA", fields: [userAId], references: [id])
  userB     User          @relation("MatchB", fields: [userBId], references: [id])
  createdAt DateTime      @default(now())
  messages  ChatMessage[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([matchId])
  @@index([createdAt])
}

model Group {
  id           String         @id @default(uuid())
  title        String
  description  String?
  universityId String?
  programme    String?
  visibility   String         @default("university") // university | programme | public
  createdById  String
  createdBy    User           @relation(fields: [createdById], references: [id])
  createdAt    DateTime       @default(now())
  members      GroupMember[]
  messages     GroupMessage[]
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  role     String   @default("member")
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([createdAt])
}

model Post {
  id         String        @id @default(uuid())
  authorId   String
  author     User          @relation(fields: [authorId], references: [id])
  content    String
  mediaUrl   String?
  visibility String        @default("university")
  isHidden   Boolean       @default(false)
  createdAt  DateTime      @default(now())
  comments   PostComment[]
  likes      PostLike[]

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Job {
  id                 String           @id @default(uuid())
  title              String
  description        String
  employmentType     String?
  location           String?
  ownerUserId        String
  ownerUser          User             @relation(fields: [ownerUserId], references: [id])
  targetUniversityId String?
  targetProgramme    String?
  isActive           Boolean          @default(true)
  isFeatured         Boolean          @default(false)
  createdAt          DateTime         @default(now())
  applications       JobApplication[]

  @@index([ownerUserId])
  @@index([isActive])
  @@index([createdAt])
}

model JobApplication {
  id          String   @id @default(uuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User     @relation(fields: [applicantId], references: [id])
  coverLetter String?
  status      String   @default("submitted")
  createdAt   DateTime @default(now())

  @@unique([jobId, applicantId])
  @@index([jobId])
  @@index([applicantId])
}

model MarketplaceListing {
  id           String   @id @default(uuid())
  type         String // rent | sale | opportunity | service
  category     String // accommodation | flatmate_wanted | electronics | books | furniture | distribution | entrepreneurship | campus_opportunity | services | events | other | local_business | promos | services_pro
  title        String
  description  String
  price        Float? // Optional - for opportunities/services, can be commission/stipend/fee
  location     String?
  universityId String?
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  vendorId     String? // For vendor items
  vendorItemId String? // Reference to VendorItem if this listing is linked to a vendor item
  stockQty      Int? // For vendor items
  schedule      Json? // Opening hours for services
  fulfillmentType String? // pickup | delivery | service_booking | coupon
  campusCoverage String[] @default([]) // Array of universityId for vendor items
  images       Json?
  contactInfo  String?
  metadata     Json? // Additional data: requirements, duration, compensation type, etc.
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([ownerId])
  @@index([vendorId])
  @@index([isActive])
  @@index([category])
  @@index([createdAt])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  context   String // marketplace | job | premium
  reference String
  amount    Float
  status    String   @default("pending") // pending | paid | failed
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
}

// Generic Badge System - Users can have multiple badges (teacher, engineer, doctor, chartered_accountant, etc.)
model UserBadge {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeType  String // "teacher", "engineer", "doctor", "chartered_accountant", "lawyer", "architect", etc.
  verified   Boolean   @default(false) // Badge is verified by admin
  verifiedAt DateTime? // When badge was verified
  verifiedBy String? // Admin ID who verified (references User.id where role='admin' or 'super_admin')
  documents  Json? // Verification documents (certificates, licenses, etc.)
  metadata   Json? // Additional badge-specific data (e.g., specialization, years of experience)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, badgeType]) // User can only have one badge of each type
  @@index([userId])
  @@index([badgeType])
  @@index([verified])
  @@index([badgeType, verified])
}

model Report {
  id             String   @id @default(uuid())
  reportedById   String
  reportedBy     User     @relation("ReportBy", fields: [reportedById], references: [id])
  reportedUserId String?
  reportedUser   User?    @relation("ReportOn", fields: [reportedUserId], references: [id])
  reason         String
  contextType    String?
  contextId      String?
  status         String   @default("pending") // pending | resolved | dismissed
  createdAt      DateTime @default(now())

  @@index([reportedById])
  @@index([reportedUserId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

model Device {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String // Unique device identifier (e.g., from expo-application)
  deviceName   String? // Device name/model
  platform     String // ios | android
  fcmToken     String? // Firebase Cloud Messaging token for push notifications
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now()) @updatedAt
  createdAt    DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([deviceId])
}

model ResearchOpportunity {
  id                 String                @id @default(uuid())
  title              String
  description        String
  researchArea       String // e.g., AI, Biology, Economics
  requirements       Json? // { skills: [], prerequisites: [], gpa: number, yearOfStudy: number }
  duration           String? // e.g., "6 months", "1 year"
  location           String // on-campus | remote | hybrid
  compensation       String? // stipend amount, "credit", "unpaid"
  teacherId          String
  teacher            User                  @relation(fields: [teacherId], references: [id])
  universityId       String
  university         University            @relation(fields: [universityId], references: [id])
  targetUniversities String[]              @default([]) // For cross-university opportunities
  targetProgrammes   String[]              @default([]) // Optional: specific programmes
  maxApplicants      Int?
  status             String                @default("open") // open | closed | filled
  applications       ResearchApplication[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @default(now()) @updatedAt

  @@index([teacherId])
  @@index([universityId])
  @@index([status])
  @@index([researchArea])
}

model ResearchApplication {
  id            String              @id @default(uuid())
  opportunityId String
  opportunity   ResearchOpportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  studentId     String
  student       User                @relation(fields: [studentId], references: [id])
  coverLetter   String?
  cvUrl         String?
  transcriptUrl String?
  status        String              @default("pending") // pending | accepted | rejected
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt

  @@unique([opportunityId, studentId]) // One application per student per opportunity
  @@index([studentId])
  @@index([opportunityId])
  @@index([status])
}

model Settings {
  id                             String   @id @default("platform")
  enableCrossUniversityMatching  Boolean  @default(false)
  enableCrossUniversityResearch  Boolean  @default(true)
  enableMarketplace              Boolean  @default(true)
  enableCareerFeatures           Boolean  @default(true)
  enableResearchFeatures         Boolean  @default(true)
  reportNotificationEmail        String?
  // Account type availability for onboarding
  enableStudentRegistration      Boolean  @default(true)
  enableAlumniRegistration       Boolean  @default(true)
  enableTeacherRegistration      Boolean  @default(true)
  enableProfessionalRegistration Boolean  @default(true)
  // Note: Allowed countries are now managed via Country.active flag
  // Profile-wise feature flags
  studentFeatures                Json? // { marketplace: boolean, career: boolean, crush: boolean, circles: boolean, feed: boolean, research: boolean }
  alumniFeatures                 Json? // { marketplace: boolean, career: boolean, circles: boolean, feed: boolean, research: boolean }
  teacherFeatures                Json? // { marketplace: boolean, career: boolean, circles: boolean, feed: boolean, research: boolean }
  professionalFeatures           Json? // { marketplace: boolean, career: boolean, circles: boolean, feed: boolean, research: boolean }
  // Badge-wise spaces - each badge type gets its own space (community) where badge holders can connect
  // e.g., { teacher: { enabled: true, name: "Research Space", accessType: "both" }, engineer: { enabled: true, name: "Engineering Space", accessType: "professional" } }
  // accessType: "student" | "professional" | "both" - determines which profile types can access this space
  badgeSpaces                    Json? // { [badgeType: string]: { enabled: boolean, name: string, description?: string, accessType: "student" | "professional" | "both" } }
  // Referral system settings
  enableReferralSystem           Boolean  @default(true)
  referralPointsPerSignup        Int      @default(10) // Points awarded when referred user signs up
  referralPointsPerVerification  Int      @default(20) // Points awarded when referred user verifies their account
  referralPointsPerDomainMatch   Int      @default(5) // Bonus points if referred user is from same domain (university/organization)
  // Age restrictions
  minAgeStudent                  Int? // Minimum age for student registration (e.g., 16)
  maxAgeStudent                  Int? // Maximum age for student registration (e.g., 35)
  minAgeProfessional             Int? // Minimum age for professional registration (e.g., 18)
  maxAgeProfessional             Int? // Maximum age for professional registration (e.g., 70)
  // Terms and conditions
  termsMessage                   String? // Message to show when user clicks terms checkbox
  termsLink                      String? // URL where full terms and conditions are displayed
  updatedAt                      DateTime @default(now()) @updatedAt
}

// Vendor Portal Models
model Vendor {
  id                    String          @id @default(uuid())
  businessName           String
  proprietorName         String
  email                  String          @unique
  phone                  String
  phoneVerified          Boolean         @default(false)
  emailVerified          Boolean         @default(false)
  tradeLicenseOrNID      String? // Trade license number or NID
  documents              Json? // KYC documents (trade license, NID, bank statement)
  bankAccount            Json? // Bank or MFS account details for payouts
  status                 String          @default("pending") // pending | approved | rejected | suspended
  approvedBy             String? // Admin ID
  approvedAt             DateTime?
  ownerId                String? // User ID if vendor owner is a UniCircle user
  owner                  User?          @relation("VendorOwner", fields: [ownerId], references: [id])
  locations               VendorLocation[]
  items                   VendorItem[]
  orders                  Order[]
  payouts                 Payout[]
  campaigns               Campaign[]
  invoices                Invoice[]
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @default(now()) @updatedAt

  @@index([status])
  @@index([email])
  @@index([ownerId])
}

model VendorLocation {
  id          String   @id @default(uuid())
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name        String // e.g., "Main Branch", "Campus Outlet"
  address     String
  latitude    Float?
  longitude   Float?
  phone       String?
  schedule    Json? // Opening hours { monday: { open: "09:00", close: "18:00" }, ... }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([vendorId])
}

model VendorItem {
  id                String   @id @default(uuid())
  vendorId          String
  vendor             Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  title              String
  description       String?
  category           String // local_business | promos | services_pro | other
  price              Float?
  stockQty           Int?
  images             Json? // Array of image URLs
  fulfillmentType    String  @default("pickup") // pickup | delivery | service_booking | coupon
  schedule           Json? // For services: booking schedule
  campusCoverage     String[] @default([]) // Array of universityId
  metadata           Json? // Additional data
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  orderItems         OrderItem[]

  @@index([vendorId])
  @@index([category])
  @@index([isActive])
}

// Orders and Checkout
model Order {
  id              String      @id @default(uuid())
  buyerId         String
  buyer           User        @relation("OrderBuyer", fields: [buyerId], references: [id])
  vendorId        String
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  items           OrderItem[]
  subtotal        Float
  fees            Float        @default(0) // Platform fees
  total           Float
  paymentMethod   String       @default("cod") // cod | mfs | card | prepaid_token
  paymentStatus   String       @default("pending") // pending | paid | failed | refunded
  status          String       @default("created") // created | confirmed | fulfilled | cancelled | refunded
  currency        String       @default("BDT") // ISO 4217 currency code - derived from country
  deliveryInfo    String? // address or pickup point; optional for service_booking
  bookingSlot     String? // ISO 8601 interval or time slot id for service_booking
  universityId    String?
  university      University?  @relation(fields: [universityId], references: [id])
  metadata        Json? // Additional order data
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @default(now()) @updatedAt

  @@index([buyerId])
  @@index([vendorId])
  @@index([status])
  @@index([universityId])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId    String
  item      VendorItem @relation(fields: [itemId], references: [id])
  title     String
  qty       Int
  unitPrice Float
  subtotal  Float

  @@index([orderId])
  @@index([itemId])
}

// Payments and Payouts
model Payout {
  id           String   @id @default(uuid())
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  periodStart  DateTime
  periodEnd    DateTime
  grossSales   Float
  platformFees Float
  adjustments  Float    @default(0) // Refunds, adjustments
  netPayable   Float
  currency     String   @default("BDT") // ISO 4217 currency code - derived from vendor's country
  status       String   @default("pending") // pending | processing | paid | failed
  disbursedAt  DateTime?
  transactionId String? // External transaction ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([vendorId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

// Billing and Pricing
model Invoice {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation("InvoiceUser", fields: [userId], references: [id])
  vendorId      String?
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
  context       String // marketplace_feature | vendor_boost | job_posting | premium_badge
  referenceId   String // ID of the item being billed (listing ID, job ID, etc.)
  amount        Float
  currency      String   @default("BDT") // ISO 4217 currency code - derived from user's country
  status        String   @default("pending") // pending | paid | failed | refunded
  paymentMethod String?
  paidAt        DateTime?
  pdfUrl        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([vendorId])
  @@index([status])
  @@index([context])
}

// Campaigns (for vendor boosts and featured listings)
model Campaign {
  id              String   @id @default(uuid())
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type            String // featured | boosted | spotlight
  targetType      String? // listing | vendor | item
  targetId        String? // ID of the target (listing ID, item ID, etc.)
  impressions     Int      @default(0)
  impressionsGuarantee Int? // For boosted campaigns
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active") // active | paused | completed | cancelled
  invoiceId       String? // Reference to invoice
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([vendorId])
  @@index([status])
  @@index([startDate, endDate])
}
